generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model App {
    id        Int      @id @default(autoincrement())
    name      String
    apiKey    String   @unique
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    events     Event[]
    sessions   Session[]
    crashes    Crash[]
    dailyStats DailyStats[]
    user       User?        @relation(fields: [userId], references: [id])
    userId     Int?
}

model Event {
    id        Int      @id @default(autoincrement())
    appId     Int
    name      String
    data      Json
    timestamp DateTime @default(now())

    // relation
    app App @relation(fields: [appId], references: [id], onDelete: Cascade)

    // index for high-volume queries (filter by app + name + time range)
    @@index([appId, name, timestamp])
}

model User {
    id        Int      @id @default(autoincrement())
    email     String   @unique
    name      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    apps App[]
}

model Session {
    id        Int       @id @default(autoincrement())
    appId     Int
    userId    String
    startTime DateTime  @default(now())
    endTime   DateTime?
    duration  Int?

    app App @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model Crash {
    id        Int      @id @default(autoincrement())
    appId     Int
    userId    String
    error     String
    stack     String
    timestamp DateTime @default(now())

    app App @relation(fields: [appId], references: [id], onDelete: Cascade)
}

model DailyStats {
    id           Int      @id @default(autoincrement())
    appId        Int
    date         DateTime
    eventCount   Int      @default(0)
    sessionCount Int      @default(0)

    app App @relation(fields: [appId], references: [id], onDelete: Cascade)

    @@unique([appId, date])
}
